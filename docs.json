{
  "$schema": "https://mintlify.com/docs.json",
  "name": "ZeroDash",
  "theme": "palm",
  "colors": {
    "primary": "#4A90E2",
    "light": "#6BA5E8",
    "dark": "#2E5F8F"
  },
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/ujwalnk/zerodash"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/ujwalnk/zerodash"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "introduction",
              "quickstart",
              "installation"
            ]
          },
          {
            "group": "Configuration",
            "pages": [
              "configuration/overview",
              "configuration/layouts",
              "configuration/tiles"
            ]
          },
          {
            "group": "Tile Types",
            "pages": [
              "tiles/application",
              "tiles/link",
              "tiles/button",
              "tiles/toggle",
              "tiles/webhook",
              "tiles/widget"
            ]
          },
          {
            "group": "Features",
            "pages": [
              "features/search",
              "features/availability-monitoring",
              "features/responsive-layouts",
              "features/text-fitting"
            ]
          },
          {
            "group": "Advanced",
            "pages": [
              "advanced/media-queries",
              "advanced/layout-urls",
              "advanced/developer-overlay",
              "advanced/deployment"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Core Modules",
            "pages": [
              "api/tile-factory",
              "api/tile-types",
              "api/layout-selector",
              "api/renderer",
              "api/search-engine"
            ]
          }
        ]
      }
    ]
  }
}
